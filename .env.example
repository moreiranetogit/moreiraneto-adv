# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Obtenha em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── GEMINI (Google AI Studio) ───────────────────────────────────────────────
# Obtenha em: aistudio.google.com → Get API Key
# ATENÇÃO: Gere uma nova chave. Nunca compartilhe a chave atual.
GEMINI_API_KEY=AIzaSy...

# ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://moreiraneto.adv.br
NEXT_PUBLIC_PORTAL_NAME=Despacho
NEXT_PUBLIC_ESCRITORIO_NOME=Moreira Neto Advocacia
NEXT_PUBLIC_AMAA_WHATSAPP=5546999999999

# ─── EMAIL (configurar depois — Resend ou SMTP) ──────────────────────────────
# Opção A: Resend (resend.com — gratuito até 3.000 e-mails/mês)
RESEND_API_KEY=re_...
EMAIL_FROM=contato@moreiraneto.adv.br

# Opção B: SMTP (Zoho Mail, Google Workspace, etc.)
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=465
# SMTP_USER=contato@moreiraneto.adv.br
# SMTP_PASS=...

# ─── WHATSAPP (integração com AMAA) ─────────────────────────────────────────
# Obtenha em: developers.facebook.com → WhatsApp Business API
# ATENÇÃO: Apenas configure se estiver integrando WhatsApp automático
# Por enquanto, interesses de adoção usam fallback (notificação para admin)
# WHATSAPP_BUSINESS_API_TOKEN=EAB...
# WHATSAPP_PHONE_NUMBER_ID=123456789...

# ─── CRON (revalidação RSS automática) ──────────────────────────────────────
# Segredo para proteger a rota /api/rss/refresh
CRON_SECRET=gere_um_uuid_aleatorio_aqui
